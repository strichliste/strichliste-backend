# PostgreSQL connection URL (required).
DATABASE_URL=postgres://strichliste:strichliste@localhost:5432/strichliste?sslmode=disable

# Address the HTTP server binds to (default :8080).
LISTEN_ADDR=:8080

# Path to the settings file served at /api/settings (default config/strichliste.yaml).
STRICHLISTE_SETTINGS_FILE=config/strichliste.yaml

# Optional: directory containing index.html to serve at "/".
# WEBROOT=/var/www/strichliste-frontend
