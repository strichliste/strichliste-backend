{% extends 'base.html.twig' %}

{% block title %}{{ 'transactions.history.title'|trans({'%name%': user.name}) }} · Strichliste{% endblock %}

{% block main %}
    <twig:PageHeader
        title="{{ 'transactions.history.title'|trans({'%name%': user.name}) }}"
        subtitle="{{ (total == 1 ? 'transactions.history.count_one' : 'transactions.history.count_other')|trans({'%count%': total}) }}"
    >
        <twig:block name="actions">
            <a class="btn" href="{{ path('users_detail', {id: user.id}) }}">&larr; {{ user.name }}</a>
        </twig:block>
    </twig:PageHeader>

    {% if rows is empty %}
        <twig:EmptyState>{{ 'transactions.history.empty'|trans }}</twig:EmptyState>
    {% else %}
        <ul class="transaction-list">
            {% for row in rows %}
                <twig:TransactionRow
                    tx="{{ row.tx }}"
                    deletable="{{ row.deletable }}"
                    ownerUserId="{{ user.id }}"
                    returnTo="history"
                />
            {% endfor %}
        </ul>

        <twig:Pagination
            currentPage="{{ page }}"
            totalPages="{{ totalPages }}"
            baseUrl="{{ path('users_transactions', {id: user.id}) }}"
        />
    {% endif %}
{% endblock %}
