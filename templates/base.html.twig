<!DOCTYPE html>
<html lang="{{ app.request.locale|default('en') }}">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        {% block meta %}
            {# Matches --headerBackground per theme (see theme.css). #}
            <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
            <meta name="theme-color" content="#1d2832" media="(prefers-color-scheme: dark)" />
        {% endblock %}
        <link rel="icon" href="{{ asset('favicon.svg') }}" type="image/svg+xml" />
        <title>{% block title %}Strichliste{% endblock %}</title>
        {% block stylesheets %}
            {{ importmap('app') }}
        {% endblock %}
    </head>
    <body
        {% block body_attributes %}
            data-controller="idle" data-idle-timeout-value="{{ setting('common.idleTimeout', 0) }}"
            data-idle-redirect-value="{{ path('users_active') }}"
        {% endblock %}
    >
        {# kept across Turbo body swaps (data-turbo-permanent) — a freshly inserted,
       already-populated live region isn't announced, so the flash controller fills these in. #}
        <div
            class="visually-hidden"
            id="flash-announcer-status"
            data-turbo-permanent
            role="status"
            aria-live="polite"
            aria-atomic="true"
        ></div>
        <div
            class="visually-hidden"
            id="flash-announcer-alert"
            data-turbo-permanent
            role="alert"
            aria-live="assertive"
            aria-atomic="true"
        ></div>

        {% block skip_link %}
            {% include '_partials/skip_link.html.twig' %}
        {% endblock %}

        {% block header %}
            {% include '_partials/header_nav.html.twig' %}
        {% endblock %}

        {% block flashes %}
            {% include '_partials/flash_messages.html.twig' %}
        {% endblock %}

        {% if app.flashes('transaction_success') is not empty %}
            <div
                hidden
                aria-hidden="true"
                data-controller="sound"
                data-sound-asset-value="{{ asset('audio/ka-ching.wav') }}"
            ></div>
        {% endif %}

        <main id="main-content" tabindex="-1">{% block main %}{% endblock %}</main>

        {% block footer %}
            <footer class="app-footer">
                <span>strichliste-web (MIT License, by schinken and sanderdrummer)</span>
                <a href="https://github.com/strichliste/strichliste-web-frontend" rel="noopener" target="_blank">
                    <twig:ux:icon name="github" class="app-footer__icon" aria-hidden="true" />
                    Code
                </a>
            </footer>
        {% endblock %}
    </body>
</html>
