{#- label doubles as the accessible name and the visible caption -#}
{% props label %}
<span class="circle-action">
    <button type="submit" class="accept-circle" aria-label="{{ label }}">
        <svg viewBox="0 0 12 9" aria-hidden="true"><path d="M1 4.5L4.5 8L11 1.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
    </button>
    <span class="circle-action__caption" aria-hidden="true">{{ label }}</span>
</span>
