{% props otherUser, direction %}
{# direction: 'to' = current user sent → other; 'from' = current user received ← other #}
<span class="transfer-address transfer-address--{{ direction }}">
    {# Text equivalent for screen readers; the arrow glyph is decorative and the
       color cue alone is not sufficient (WCAG 1.3.1 / 1.4.1). #}
    <span class="visually-hidden">{{ (direction == 'to' ? 'transactions.transfer.direction_to' : 'transactions.transfer.direction_from')|trans }} </span>
    <span aria-hidden="true">{%- if direction == 'to' -%}&rarr; {% else %}&larr; {% endif -%}</span>
    <a href="{{ path('users_detail', {id: otherUser.id}) }}">{{ otherUser.name }}</a>
</span>
