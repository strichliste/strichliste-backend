{#- label doubles as the accessible name and the visible caption -#}
{% props label, href = null %}
{%- set tag = href ? 'a' : 'button' -%}
<span class="circle-action">
    <{{ tag }} class="form-cancel-circle"
       {%- if href %} href="{{ href }}"{% else %} type="button"{% endif %}
       aria-label="{{ label }}">
        <twig:ux:icon name="close" aria-hidden="true" />
    </{{ tag }}>
    <span class="circle-action__caption" aria-hidden="true">{{ label }}</span>
</span>
