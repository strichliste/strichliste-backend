{% extends 'base.html.twig' %}

{% block title %}{{ user.name }} · Strichliste{% endblock %}

{% block main %}
    {# The barcode scanner listens at document level on the whole user detail
       page (any tab). A USB-HID burst into the page commits a buy via the
       hidden form POST built by the controller — no visible input. #}
    <div data-controller="barcode-listener"
         data-barcode-listener-action-value="{{ path('transactions_buy', {id: user.id}) }}"
         data-barcode-listener-token-value="{{ csrf_token('buy' ~ user.id) }}"></div>

    <section class="user-hero" aria-labelledby="user-hero-name">
        <h1 id="user-hero-name" class="user-hero__name">
            <span>{{ user.name }}</span>
        </h1>
        <div class="user-hero__balance">
            <twig:BalancePill amount="{{ user.balance }}" currency="{{ currencySymbol }}" />
        </div>
    </section>

    {% if user.disabled %}
        {% include 'users/_disabled_banner.html.twig' %}
    {% endif %}

    {% include 'users/_action_tabs.html.twig' with {
        user: user,
        activeTab: activeTab,
        showSendTab: showSendTab,
        showBuyTab: showBuyTab,
        showPaypalTab: showPaypalTab,
    } only %}

    {# Active tab form appears ABOVE the always-visible actions/transactions. #}
    {% if activeTab %}
        <section class="tab-panel" aria-label="{{ ('user.detail.tabs.' ~ activeTab)|trans }}">
            {% if activeTab == 'edit' %}
                {{ include('users/_edit_form.html.twig', {form: editForm, user: user}) }}
            {% elseif activeTab == 'send' %}
                {{ include('users/_tab_send.html.twig', {send: send, user: user, currency: currencySymbol}) }}
            {% elseif activeTab == 'buy' %}
                {{ include('users/_tab_buy.html.twig', {user: user, buy: buy, currency: currencySymbol}) }}
            {% elseif activeTab == 'paypal' %}
                {{ include('users/_tab_paypal.html.twig', {user: user}) }}
            {% endif %}
        </section>
    {% endif %}

    <div class="user-detail-grid">
        {# LEFT: always the deposit/dispense step buttons + custom amount. #}
        <aside class="user-detail-grid__actions">
            {% if send %}
                {% include 'users/_default_actions.html.twig' with {send: send, user: user, currency: currencySymbol} only %}
            {% endif %}
        </aside>

        {# RIGHT: always the recent transactions list. #}
        <section aria-labelledby="recent-tx-heading" class="recent-tx">
            <h2 id="recent-tx-heading" class="visually-hidden">{{ 'user.detail.recent_transactions'|trans }}</h2>
            {% if recentTransactions is empty %}
                <twig:EmptyState>{{ 'user.detail.no_transactions'|trans }}</twig:EmptyState>
            {% else %}
                <ul class="transaction-list">
                    {% for row in recentTransactions %}
                        <twig:TransactionRow tx="{{ row.tx }}" currency="{{ currencySymbol }}" deletable="{{ row.deletable }}" ownerUserId="{{ user.id }}" />
                    {% endfor %}
                </ul>
            {% endif %}
            <div class="recent-tx__footer">
                <a href="{{ path('users_transactions', {id: user.id}) }}" class="user-detail-link">
                    <svg class="user-detail-link__icon" viewBox="0 0 16 16" aria-hidden="true">
                        <path fill="currentColor" d="M8 1l4 4-1 1-2-2v8H7V4L5 6 4 5z"/>
                        <path fill="currentColor" d="M8 15l-4-4 1-1 2 2V4h2v8l2-2 1 1z"/>
                    </svg>
                    {{ 'user.detail.view_all'|trans }}
                </a>
                <a href="{{ path('metrics_user', {id: user.id}) }}" class="user-detail-link">
                    <svg class="user-detail-link__icon" viewBox="0 0 16 16" aria-hidden="true">
                        <path fill="currentColor" d="M2 14V2h2v12zM5 14V7h2v7zM8 14V4h2v10zM11 14V8h2v6z"/>
                    </svg>
                    {{ 'user.detail.metrics'|trans }}
                </a>
            </div>
        </section>
    </div>
{% endblock %}
