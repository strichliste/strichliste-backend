{#- clicking the active tab links back to the no-tab state -#}
{%-
    set tabs = [
        {key: 'send',   gated: showSendTab},
        {key: 'buy',    gated: showBuyTab},
        {key: 'edit',   gated: true},
        {key: 'paypal', gated: showPaypalTab},
    ]
-%}

<nav class="user-tabs" aria-label="{{ 'user.detail.tabs_aria'|trans }}">
    {% for tab in tabs|filter(t => t.gated) %}
        {%- set href = path('users_detail', tab.key == activeTab ? {id: user.id} : {id: user.id, tab: tab.key}) -%}
        <a href="{{ href }}" {% if activeTab == tab.key %}aria-current="page"{% endif %}>
            {# static names so ux-icons inlines the SVG at compile time #}
            {% if tab.key == 'send' %}
                <twig:ux:icon name="tab-send" aria-hidden="true" /> {% elseif tab.key == 'buy' %}<twig:ux:icon
                    name="tab-buy"
                    aria-hidden="true"
                />
                {% elseif tab.key == 'edit' %}<twig:ux:icon name="tab-edit" aria-hidden="true" />
                {% elseif tab.key == 'paypal' %}<twig:ux:icon name="tab-paypal" aria-hidden="true" />
            {% endif %}
            {{ ('user.detail.tabs.' ~ tab.key)|trans }}
        </a>
    {% endfor %}
</nav>
