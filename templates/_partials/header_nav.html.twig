{%- set route = app.request.attributes.get('_route') -%}
{%- macro links(route) -%}
    <a href="{{ path('articles_index') }}" {% if route starts with 'articles_' %}aria-current="page"{% endif %}>
        {{ 'nav.articles'|trans }}
    </a>
    {% if setting('payment.splitInvoice.enabled', false) %}
        <a
            href="{{ path('split_invoice_index') }}"
            {% if route == 'split_invoice_index' %}aria-current="page"{% endif %}
        >
            {{ 'nav.split_invoice'|trans }}
        </a>
    {% endif %}
    <a
        href="{{ path('metrics_global') }}"
        {% if route == 'metrics_global' or route == 'metrics_user' %}aria-current="page"{% endif %}
    >
        {{ 'nav.metrics'|trans }}
    </a>
{%- endmacro -%}
<header class="app-header" role="banner">
    <a
        class="app-header__brand"
        href="{{ path('users_active') }}"
        {% if route starts with 'users_' or route == 'home' %}aria-current="page"{% endif %}
    >
        <twig:ux:icon name="brand" class="app-header__brand-icon" aria-hidden="true" />
        <span>{{ 'app.brand'|trans }}</span>
    </a>
    <nav class="app-header__nav" aria-label="{{ 'nav.main'|trans }}">{{ _self.links(route) }}</nav>
    {# phone burger — details, so it works without JS #}
    <details class="app-header__menu" data-controller="disclosure">
        <summary>
            <twig:ux:icon name="menu" aria-hidden="true" />
            <span class="visually-hidden">{{ 'nav.menu'|trans }}</span>
        </summary>
        <nav class="app-header__menu-panel" aria-label="{{ 'nav.main'|trans }}">{{ _self.links(route) }}</nav>
    </details>
    <form method="get" action="{{ path('search_results') }}" class="app-header__search" role="search">
        <label class="visually-hidden" for="hsearch">{{ 'nav.search.input_label'|trans }}</label>
        <input type="text" id="hsearch" name="q" placeholder="{{ 'nav.search.input_placeholder'|trans }}" />
        <button type="submit" aria-label="{{ 'nav.search.submit'|trans }}">
            <twig:ux:icon name="search" aria-hidden="true" />
        </button>
    </form>
</header>
