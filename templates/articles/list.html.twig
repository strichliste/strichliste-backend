{% extends 'base.html.twig' %}

{% block title %}{{ (active ? 'articles.list.title.active' : 'articles.list.title.inactive')|trans }} · Strichliste{% endblock %}

{% block main %}
    <h1 class="visually-hidden">{{ (active ? 'articles.list.title.active' : 'articles.list.title.inactive')|trans }}</h1>

    {% if active %}
        <a class="fab fab--floating" href="{{ path('articles_create') }}" aria-label="{{ 'articles.list.add_cta'|trans }}">+</a>
    {% endif %}
    <div class="list-toolbar">
        <nav class="tabs" aria-label="{{ 'articles.list.filter_aria'|trans }}">
            <a href="{{ path('articles_active') }}" {% if active %}aria-current="page"{% endif %}>{{ 'articles.list.title.active'|trans }}</a>
            <a href="{{ path('articles_inactive') }}" {% if not active %}aria-current="page"{% endif %}>{{ 'articles.list.title.inactive'|trans }}</a>
        </nav>
    </div>

    {% if tags is not empty %}
        <div class="tag-filter">
            <a class="tag-chip {% if activeTag is null %}tag-chip--active{% endif %}"
               {% if activeTag is null %}aria-current="true"{% endif %}
               href="{{ path(active ? 'articles_active' : 'articles_inactive') }}">{{ 'articles.list.filter.all'|trans }}</a>
            {% for tag in tags %}
                <a class="tag-chip {% if activeTag == tag.tag %}tag-chip--active{% endif %}"
                   {% if activeTag == tag.tag %}aria-current="true"{% endif %}
                   href="{{ path(active ? 'articles_active' : 'articles_inactive') }}?tag={{ tag.tag|url_encode }}">{{ tag.tag }}</a>
            {% endfor %}
        </div>
    {% endif %}

    {% if articles is empty %}
        {% if active %}
            <twig:EmptyState title="{{ 'articles.list.empty'|trans }}">
                <a class="fab" href="{{ path('articles_create') }}" aria-label="{{ 'articles.list.add_cta'|trans }}">+</a>
            </twig:EmptyState>
        {% else %}
            <twig:EmptyState>{{ 'articles.list.empty_inactive'|trans }}</twig:EmptyState>
        {% endif %}
    {% else %}
        <ul class="article-rows">
            {% for article in articles %}
                <li class="article-row {% if not article.active %}article-row--inactive{% endif %}">
                    <a href="{{ path('articles_edit', {id: article.id}) }}" class="article-row__link">
                        <span class="article-row__name">{{ article.name }}</span>
                        <span class="article-row__price">{{ article.amount|currency_format(signed=false) }}</span>
                    </a>
                </li>
            {% endfor %}
        </ul>

        <twig:Pagination currentPage="{{ page }}" totalPages="{{ totalPages }}"
                         baseUrl="{{ active ? path('articles_active') : path('articles_inactive') }}"
                         extraParams="{{ activeTag ? {tag: activeTag} : {} }}" />
    {% endif %}
{% endblock %}
