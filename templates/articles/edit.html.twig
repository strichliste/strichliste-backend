{% extends 'base.html.twig' %}

{% block title %}{{ 'articles.edit.title'|trans({'%name%': article.name}) }} · Strichliste{% endblock %}

{% block main %}
    <h1 class="visually-hidden">{{ 'articles.edit.title'|trans({'%name%': article.name}) }}</h1>

    {% if priceFrozen %}
        <div class="banner banner--info">
            <strong>{{ 'articles.edit.precursor_warning_title'|trans }}</strong>
            <p>{{ 'articles.edit.precursor_warning_body'|trans }}</p>
        </div>
    {% endif %}

    <div class="article-form-grid">
        <div>
            <div class="card article-form">
                <h2 class="article-form__name">{{ article.name }}</h2>
                {{ form_start(form) }}
                    {{ form_row(form.name) }}
                    {{ form_row(form.amount) }}
                    {{ form_row(form.active) }}
                    <div class="form-actions form-actions--circles">
                        <twig:CancelCircle href="{{ article.active ? path('articles_active') : path('articles_inactive') }}" label="{{ 'common.cancel'|trans }}" />
                        <twig:AcceptCheck label="{{ 'articles.edit.submit'|trans }}" />
                    </div>
                {{ form_end(form) }}
            </div>

            <section class="card article-form barcode-section">
                <h3 class="article-form__subhead">{{ 'articles.barcodes.heading'|trans|upper }}</h3>
                <ul class="chip-list">
                    {% for barcode in article.barcodes %}
                        <li class="chip">
                            <span class="chip__label">{{ barcode.barcode }}</span>
                            <form method="post" action="{{ path('articles_barcodes_delete', {id: article.id, bid: barcode.id}) }}" class="inline-form">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_barcode' ~ barcode.id) }}">
                                <button type="submit" class="chip__remove" aria-label="{{ 'articles.barcodes.remove'|trans({'%barcode%': barcode.barcode}) }}">
                                    <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M3 3L13 13M13 3L3 13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                                </button>
                            </form>
                        </li>
                    {% else %}
                        <li class="chip-list__empty">{{ 'articles.barcodes.empty'|trans }}</li>
                    {% endfor %}
                </ul>
                <form method="post" action="{{ path('articles_barcodes_add', {id: article.id}) }}" class="inline-add">
                    <label>
                        {{ 'articles.barcodes.add_label'|trans }}
                        <input type="text" name="barcode" maxlength="32" required>
                    </label>
                    <input type="hidden" name="_token" value="{{ csrf_token('add_barcode' ~ article.id) }}">
                    <button type="submit" class="btn btn--add">+ {{ 'articles.barcodes.add_submit'|trans }}</button>
                </form>
            </section>
        </div>

        <div>
            <section class="card article-form tag-section">
                <h3 class="article-form__subhead">{{ 'articles.tags.heading'|trans|upper }}</h3>
                <ul class="chip-list">
                    {% for tag in article.tags %}
                        <li class="chip">
                            <span class="chip__label">{{ tag.tag }}</span>
                            <form method="post" action="{{ path('articles_tags_delete', {id: article.id, tid: tag.id}) }}" class="inline-form">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_tag' ~ tag.id) }}">
                                <button type="submit" class="chip__remove" aria-label="{{ 'articles.tags.remove'|trans({'%tag%': tag.tag}) }}">
                                    <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M3 3L13 13M13 3L3 13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                                </button>
                            </form>
                        </li>
                    {% else %}
                        <li class="chip-list__empty">{{ 'articles.tags.empty'|trans }}</li>
                    {% endfor %}
                </ul>
                <form method="post" action="{{ path('articles_tags_add', {id: article.id}) }}" class="inline-add">
                    <label>
                        {{ 'articles.tags.add_label'|trans }}
                        <input type="text" name="tag" maxlength="64" required>
                    </label>
                    <input type="hidden" name="_token" value="{{ csrf_token('add_tag' ~ article.id) }}">
                    <button type="submit" class="btn btn--add">+ {{ 'articles.tags.add_submit'|trans }}</button>
                </form>
            </section>
        </div>
    </div>

    {% if article.active %}
        <div class="article-form-archive">
            <a class="btn btn--red" href="{{ path('articles_delete', {id: article.id}) }}">{{ 'articles.edit.archive_cta'|trans }}</a>
        </div>
    {% endif %}
{% endblock %}
