{% extends 'base.html.twig' %}

{% block title %}{{ 'articles.create.title'|trans }} · Strichliste{% endblock %}

{% block main %}
    <div class="card article-form">
        {# uppercased via CSS, not in the text — kinder to screen readers and non-ASCII locales #}
        <h1 class="article-form__subhead">{{ 'articles.create.title'|trans }}</h1>
        {{ form_start(form) }}
            {{ form_row(form.name) }}
            {{ form_row(form.amount) }}
            <div class="form-actions form-actions--circles">
                <twig:CancelCircle href="{{ path('articles_active') }}" label="{{ 'common.cancel'|trans }}" />
                <twig:AcceptCheck label="{{ 'articles.create.submit'|trans }}" />
            </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
