# This file is read by Symfony (app defaults) AND by Docker Compose (variable
# interpolation in compose*.yaml). In all environments, the following files are
# loaded if they exist, the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=afcb8ed6bf80cf0d8d9196390e06a408
#TRUSTED_PROXIES=127.0.0.1,127.0.0.2
#TRUSTED_HOSTS=localhost,example.com
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Docker defaults to the bundled Postgres service (see compose.yaml). To use another
# database instead, set DATABASE_URL here and disable the bundled Postgres with
# COMPOSE_PROFILES= (empty, below). Any Doctrine DSN works:
#   DATABASE_URL="sqlite:////app/var/data.db"
#   DATABASE_URL="mysql://strichliste:secret@192.168.1.10:3306/strichliste?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
#   DATABASE_URL="postgresql://strichliste:secret@db.example.com:5432/strichliste?serverVersion=16&charset=utf8"
#
# For local development without Docker, set a DSN in .env.local instead, e.g.:
#   DATABASE_URL="sqlite:///%kernel.project_dir%/var/dev.db"
###< doctrine/doctrine-bundle ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN=^https?://localhost(:[0-9]+)?$
###< nelmio/cors-bundle ###

###> docker compose ###
# Runs the bundled Postgres service; set to empty (COMPOSE_PROFILES=) when DATABASE_URL
# above points at another database.
COMPOSE_PROFILES=database
#
# Bundled Postgres credentials (compose.yaml defaults shown; uncomment to change — the
# password is only applied on the first start, before the database volume exists):
#POSTGRES_USER=strichliste
#POSTGRES_PASSWORD=strichliste
#POSTGRES_DB=strichliste
#POSTGRES_VERSION=16
#
# TLS: localhost = self-signed local CA, real hostname = Let's Encrypt, ":80" = plain HTTP (LAN-IP kiosks).
#SERVER_NAME=localhost
#
# Published ports:
#HTTP_PORT=80
#HTTPS_PORT=443
#HTTP3_PORT=443
###< docker compose ###
