{
    "type": "project",
    "license": "MIT",
    "name": "strichliste/strichliste-backend",
    "description": "Backend component of strichliste, a digital tallysheet",
    "require": {
        "php": "^8.4.1",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "ext-json": "*",
        "doctrine/dbal": "^4.4",
        "doctrine/doctrine-bundle": "^3.2",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.3",
        "nelmio/api-doc-bundle": "^5.10",
        "nelmio/cors-bundle": "^2.6",
        "php-mqtt/client": "^2.3",
        "symfony/asset": "^8.1",
        "symfony/asset-mapper": "^8.1",
        "symfony/console": "^8.1",
        "symfony/dotenv": "^8.1",
        "symfony/flex": "^2.4",
        "symfony/form": "^8.1",
        "symfony/framework-bundle": "^8.1",
        "symfony/runtime": "^8.1",
        "symfony/security-csrf": "^8.1",
        "symfony/serializer": "^8.1",
        "symfony/stimulus-bundle": "^2.35",
        "symfony/translation": "^8.1",
        "symfony/twig-bundle": "^8.1",
        "symfony/ux-autocomplete": "^3.1",
        "symfony/ux-icons": "^3.1",
        "symfony/ux-turbo": "^2.35",
        "symfony/ux-twig-component": "^2.35",
        "symfony/validator": "^8.1",
        "symfony/yaml": "^8.1",
        "twig/extra-bundle": "^3.24",
        "twig/intl-extra": "^3.24"
    },
    "require-dev": {
        "dama/doctrine-test-bundle": "^8.6",
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.2",
        "phpstan/phpstan-doctrine": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^11.5",
        "rector/rector": "^2.4",
        "symfony/browser-kit": "^8.1",
        "symfony/css-selector": "^8.1",
        "symfony/ldap": "^8.1",
        "symfony/maker-bundle": "^1.6"
    },
    "config": {
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true,
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true,
            "phpstan/extension-installer": true
        },
        "platform": {
            "php": "8.4.1"
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php71": "*",
        "symfony/polyfill-php70": "*",
        "symfony/polyfill-php56": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "^8.1"
        }
    }
}
